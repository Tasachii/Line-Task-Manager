# LINE channel credentials (from LINE Developers Console)
LINE_CHANNEL_SECRET=your_channel_secret
LINE_CHANNEL_ACCESS_TOKEN=your_channel_access_token

# PostgreSQL
DATABASE_URL=postgres://line:line@localhost:5432/line_task_manager

# server
PORT=3000

# Keyword that marks a message as a task
TASK_KEYWORD=/task

# --- Security (set in production) ---
# Single shared board key (one LINE group) — leave unset to disable auth (dev mode).
#BOARD_PASSWORD=change_me
# Per-group isolation (multiple LINE groups): JSON map { "<group_id>": "<board_key>" }.
# Each key authorizes exactly one group; a key for group A can never read group B.
# Takes precedence over BOARD_PASSWORD. Leave unset for a single-group deploy.
#BOARD_GROUPS={"Cabc123...":"keyA","Cdef456...":"keyB"}
# Restrict origins allowed to call the API/WebSocket — leave unset for * (dev mode)
#CORS_ORIGIN=https://board.example.com
# Per-IP rate limit on the board API (webhook + /health are exempt)
#THROTTLE_LIMIT=120
#THROTTLE_TTL_MS=60000
# Max LINE events processed concurrently per webhook delivery (bounds AI/DB load under burst)
#WEBHOOK_CONCURRENCY=3

# --- LINE group notifications ---
# Statuses that trigger a push notification (comma-separated) — reduce to save OA quota, e.g. NOTIFY_STATUSES=done
NOTIFY_STATUSES=todo,in_process,test,done
# Notify when someone is assigned to a task (true/false)
NOTIFY_ASSIGN=true

# --- AI task extraction from natural language (optional) ---
# Set the API key to let Claude screen messages that have no keyword
#ANTHROPIC_API_KEY=sk-ant-...
# Model used for extraction (default: claude-haiku-4-5 — switch to claude-opus-4-8 for higher accuracy)
#AI_EXTRACT_MODEL=claude-haiku-4-5
